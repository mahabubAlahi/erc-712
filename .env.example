# Deployer private key (hex, with or without leading 0x). Required for broadcasting.
# For local Anvil you can use one of its pre-funded default keys.
PRIVATE_KEY=

# Address whose EIP-712 vouchers the contract will trust.
# Optional — defaults to the deployer address if left unset.
AUTHORIZER=

# RPC endpoints (referenced by foundry.toml [rpc_endpoints]).
SEPOLIA_RPC_URL=
MAINNET_RPC_URL=

# Etherscan API key, used by `forge script --verify`.
ETHERSCAN_API_KEY=
