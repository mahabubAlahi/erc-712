# Copy to .env and fill in. Loaded via `node --env-file=.env signAndVerify.js`.
# .env is gitignored — never commit real keys.

# Deployed PaymentVerifierOZ address (required).
CONTRACT=

# JSON-RPC endpoint. Default: http://127.0.0.1:8545 (local Anvil).
RPC_URL=http://127.0.0.1:8545

# Key that signs the voucher — must equal the contract's authorizer(). Required.
AUTHORIZER_KEY=

# Voucher fields (all optional — sensible defaults in the script).
RECIPIENT=
AMOUNT=
NONCE=
DEADLINE=
